            "hash": "2f3a31ba454732ae24d3df363949f476a2f55483f103a0764b4edc1f843b719d"
        },
        "32bit": {
            "url": "https://github.com/dream7180/foobox-en/releases/download/8.8/foobox_x86.en.v8.8-1.exe#/dl.7z_",
            "hash": "e5904572ce5c6941279565b436ba1e075760b8e6c9751a1b8e11cec3365e5911"
        }
    },
    "installer": {
        "script": [
            "$fb2k_app_path = \"$scoopdir\\apps\\foobar2000\\current\".Replace('\\', '\\\\')",
            "$fb2k_profile_path = \"$scoopdir\\persist\\foobar2000\\profile\".Replace('\\', '\\\\')",
            "Expand-7zipArchive \"$dir\\dl.7z_\" \"$dir\"",
            "Copy-Item \"$dir\\`$_12_\\*\" \"$fb2k_profile_path\" -Recurse -Force",
            "Copy-Item \"$dir\\icons\" \"$fb2k_app_path\" -Recurse -Force",
            "Copy-Item \"$dir\\themes\" \"$fb2k_app_path\" -Recurse -Force",
            "Remove-Item \"$dir\\*\" -Recurse -Force"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dream7180/foobox-en/releases/download/$version/foobox_x64.en.v$version-1.exe#/dl.7z_"
            },
            "32bit": {
                "url": "https://github.com/dream7180/foobox-en/releases/download/$version/foobox_x86.en.v$version-1.exe#/dl.7z_"
            }
        }
    }
}
