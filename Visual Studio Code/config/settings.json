            "icon": "bug"
        },
        "HACK": {
            "background": "#ff966c",
            "foreground": "#222436",
            "icon": "flame"
        },
        "NOTE": {
            "background": "#82aaff",
            "foreground": "#222436",
            "icon": "note"
        },
        "PREF": {
            "background": "#fca7ea",
            "foreground": "#222436",
            "icon": "clock"
        },
        "TEST": {
            "background": "#4fd6be",
            "foreground": "#222436",
            "icon": "beaker"
        },
        "TODO": {
            "background": "#c3e88d",
            "foreground": "#222436",
            "icon": "check"
        },
        "WARN": {
            "background": "#ffc777",
            "foreground": "#222436",
            "icon": "alert"
        }
    },
    "vscode-neovim.ctrlKeysForNormalMode": [
        "a",
        "b",
        "c",
        "d",
        "e",
        "h",
        "j",
        "k",
        "l",
        "q",
        "r",
        "t",
        "u",
        "v",
        "x",
        "y",
        "z",
        "/",
        "]",
        "right",
        "left",
        "up",
        "down",
        "backspace",
        "delete"
    ],
    "window.density.editorTabHeight": "compact",
    "window.dialogStyle": "custom",
    "window.menuBarVisibility": "compact",
    "window.zoomLevel": 2,
    "wordcount_cjk.statusBarTextTemplate": "共 ${cjk} 字 ${en_words} 单词",
    "wordcount_cjk.statusBarTooltipTemplate": "中文字数：\\t\\t${cjk}\\n英文单词数：\\t\\t${en_words}\\nASCII 字符数：\\t${ascii}\\n非 ASCII 字符数：\\t${total - ascii}\\n空白字符数：\\t\\t${whitespace}\\n非空白字符数：\\t${total - whitespace}\\n总字符数：\\t\\t${total}",
    "workbench.colorCustomizations": {
        "editor.lineHighlightBackground": "#1073cf2d",
        "editor.lineHighlightBorder": "#9fced11f",
        "editor.selectionHighlightBackground": "#ffffff10",
        "editor.selectionHighlightBorder": "#dddddd",
        "editorCursor.foreground": "#528bff",
        "minimap.background": "#22243633",
        "minimapSlider.background": "#9fced11f",
        "notebook.cellEditorBackground": "#21252b",
        "tab.activeBorder": "#ff966c",
        "titleBar.inactiveBackground": "#222436"
    },
    "workbench.colorTheme": "Tokyo Night Storm",
    "workbench.editor.focusRecentEditorAfterClose": false,
    "workbench.editor.wrapTabs": true,
    "workbench.editorAssociations": {
        "{git,git-graph}:/**/*.{md,csv,svg}": "default",
        "{git,gitlens,git-graph}:/**/*.{md,csv,svg}": "default",
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.drawio": "hediet.vscode-drawio-text",
        "*.epub": "cweijan.epubViewer",
        "*.gif": "cweijan.officeViewer",
        "*.md": "default"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.localHistory.enabled": false,
    "workbench.panel.showLabels": false,
    "workbench.startupEditor": "none",
    "workbench.tree.enableStickyScroll": true
}