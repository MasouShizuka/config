{
    "Module template": {
        "prefix": "M",
        "body": [
            "local M = {}",
            "${TM_SELECTED_TEXT}$0",
            "return M"
        ],
        "description": "Module template"
    },
    "Plugin template": {
        "prefix": "plugin_template",
        "body": [
            "local M = {}",
            "",
            "M.setup = function(opts)",
            "    opts = opts or {}",
            "",
            "    ${TM_SELECTED_TEXT}$0",
            "end",
            "",
            "return M"
        ],
        "description": "Plugin template"
    },
    "Plugin template with config": {
        "prefix": "plugin_template_with_config",
        "body": [
            "local M = {}",
            "",
            "local config = {}",
            "",
            "M.setup = function(opts)",
            "    opts = opts or {}",
            "    config = vim.tbl_deep_extend(\"force\", config, opts)",
            "",
            "    ${TM_SELECTED_TEXT}$0",
            "end",
            "",
            "return M"
        ],
        "description": "Plugin template with config"
    }
}