        "[ ]",
        "[x]",
    ],
    "todo-tree.highlights.customHighlight": {
        "FIX": {
            "background": "#e06c75",
            "foreground": "black",
            "icon": "bug"
        },
        "HACK": {
            "background": "#d19a66",
            "foreground": "black",
            "icon": "flame"
        },
        "NOTE": {
            "background": "#61afef",
            "foreground": "black",
            "icon": "note"
        },
        "PREF": {
            "background": "#c678dd",
            "foreground": "black",
            "icon": "clock"
        },
        "TEST": {
            "background": "#56b6c2",
            "foreground": "black",
