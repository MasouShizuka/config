{
    "[bat]": {
        "editor.detectIndentation": true,
        "editor.tabSize": 4,
        "editor.trimAutoWhitespace": true,
        "editor.useTabStops": false,
        "files.encoding": "gbk"
    },
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "[plaintext]": {
        "files.encoding": "gbk"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "auto-close-tag.activationOnLanguage": [
        "xml",
        "php",
        "blade",
        "ejs",
        "jinja",
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "plaintext",
        "markdown",
        "vue",
        "liquid",
        "erb",
        "lang-cfml",
        "cfml",
        "HTML (Eex)"
    ],
    "backgroundCover.imagePath": "d:\\Pictures\\サクラ吹雪.png",
    "backgroundCover.opacity": 0.1,
    "black-formatter.args": [
        "--skip-string-normalization"
    ],
    "code-runner.executorMap": {
        "c": "cd $dirWithoutTrailingSlash && gcc $fileName -o $fileNameWithoutExt.exe && $dir$fileNameWithoutExt.exe",
        "cpp": "cd $dirWithoutTrailingSlash && g++ $fileName -o $fileNameWithoutExt.exe && $dir$fileNameWithoutExt.exe",
        "java": "cd $dirWithoutTrailingSlash && javac -encoding utf-8 $fileName && java $fileNameWithoutExt",
        "shellscript": "cd $dirWithoutTrailingSlash && bash $fileName"
    },
    "code-runner.runInTerminal": true,
    "debug.console.fontSize": 20,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": true,
    "editor.cursorSurroundingLines": 5,
    "editor.detectIndentation": false,
    "editor.find.autoFindInSelection": "multiline",
    "editor.find.seedSearchStringFromSelection": "selection",
    "editor.fontFamily": "Sarasa Mono SC Nerd Font",
    "editor.fontLigatures": true,
    "editor.fontSize": 20,
    "editor.guides.bracketPairs": true,
    "editor.inlineSuggest.enabled": true,
    "editor.lineNumbers": "relative",
    "editor.minimap.renderCharacters": false,
    "editor.minimap.showSlider": "always",
    "editor.mouseWheelZoom": true,
    "editor.renderLineHighlight": "all",
    "editor.renderWhitespace": "trailing",
    "editor.suggest.preview": true,
    "editor.suggest.showStatusBar": true,
    "editor.suggestSelection": "first",
    "editor.wordWrap": "on",
    "explorer.confirmDragAndDrop": false,
    "files.associations": {
        "*.txt": "plaintext"
    },
    "files.autoGuessEncoding": true,
    "files.autoSave": "afterDelay",
    "github.copilot.enable": {
        "*": true,
        "markdown": false,
        "plaintext": true,
        "yaml": false
    },
    "hediet.vscode-drawio.codeLinkActivated": true,
    "hediet.vscode-drawio.theme": "Kennedy",
    "jupyter.askForKernelRestart": false,
    "Lua.diagnostics.globals": [
        "mp"
    ],
    "Lua.diagnostics.neededFileStatus": {
        "ambiguity-1": "Opened",
        "circle-doc-class": "Opened",
        "close-non-object": "Opened",
        "count-down-loop": "Opened",
        "different-requires": "Opened",
        "doc-field-no-class": "Opened",
        "duplicate-doc-alias": "Opened",
        "duplicate-doc-field": "Opened",
        "duplicate-doc-param": "Opened",
        "duplicate-index": "Opened",
        "duplicate-set-field": "Opened",
        "global-in-nil-env": "Opened",
        "lowercase-global": "Opened",
        "newfield-call": "Opened",
        "newline-call": "Opened",
        "unbalanced-assignments": "Opened",
        "undefined-doc-class": "Opened",
        "undefined-doc-name": "Opened",
        "undefined-doc-param": "Opened",
        "undefined-env-child": "Opened",
        "undefined-global": "Opened",
        "unknown-diag-code": "Opened"
    },
    "Lua.telemetry.enable": false,
    "markdown-preview-enhanced.chromePath": "C:\\Users\\MasouShizuka\\AppData\\Local\\Vivaldi\\Application\\vivaldi.exe",
    "markdown-preview-enhanced.mathRenderingOption": "MathJax",
    "markdown-preview-enhanced.previewTheme": "one-dark.css",
    "markdown.extension.list.indentationSize": "inherit",
    "markdownlint.config": {
        "MD007": false,
        "MD009": false,
        "MD024": false,
        "MD025": false,
        "MD032": false,
        "MD033": false,
        "MD037": false,
        "MD040": false
    },
    "markdownShortcuts.icons.citations": true,
    "markdownShortcuts.icons.image": true,
    "markdownShortcuts.icons.link": true,
    "notebook.cellToolbarLocation": {
        "default": "left",
        "jupyter-notebook": "left"
    },
    "notebook.displayOrder": [
        "image/png",
        "text/plain"
    ],
    "notebook.lineNumbers": "on",
    "oneDarkPro.italic": false,
    "pasteImage.path": "${currentFileDir}\\_images",
    "python.defaultInterpreterPath": "C:\\Users\\MasouShizuka\\miniconda3\\python.exe",
    "python.languageServer": "Pylance",
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "security.workspace.trust.enabled": false,
    "shellcheck.exclude": [
        "2148"
    ],
    "sqltools.connections": [
        {
            "database": "Shizuka",
            "driver": "MySQL",
            "mysqlOptions": {
                "authProtocol": "default"
            },
            "name": "Shizuka",
            "password": "root",
            "port": 3306,
            "previewLimit": 50,
            "server": "localhost",
            "username": "root"
        }
    ],
    "sqltools.useNodeRuntime": true,
    "sshfs.configs": [],
    "swapdiff.ClosePreviousDiff": true,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 20,
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.tabs.location": "left",
    "vscode-neovim.neovimExecutablePaths.win32": "D:\\Tools\\Neovim\\bin\\nvim.exe",
    "window.dialogStyle": "custom",
    "workbench.colorCustomizations": {
        "editor.lineHighlightBackground": "#1073cf2d",
        "editor.lineHighlightBorder": "#9fced11f",
        "editor.selectionHighlightBackground": "#ffffff10",
        "editor.selectionHighlightBorder": "#dddddd",
        "editorCursor.foreground": "#528bff",
        "notebook.cellEditorBackground": "#21252b",
        "tab.activeBorder": "#d19a66",
        "titleBar.inactiveBackground": "#282c34"
    },
    "workbench.colorTheme": "One Dark Pro Flat",
    "workbench.editor.defaultBinaryEditor": "hexEditor.hexedit",
    "workbench.editor.wrapTabs": true,
    "workbench.editorAssociations": {
        "*.gif": "cweijan.officeViewer",
        "*.ipynb": "jupyter-notebook",
        "*.md": "default"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.list.automaticKeyboardNavigation": false,
    "workbench.localHistory.enabled": false,
    "workbench.startupEditor": "none"
}