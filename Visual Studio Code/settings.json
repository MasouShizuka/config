{
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one",
        "editor.quickSuggestions": {
            "comments": false,
            "other": true,
            "strings": true
        }
    },
    "[plaintext]": {
        "files.encoding": "gbk"
    },
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.organizeImports": true
        },
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.formatOnType": true
    },
    "auto-run-command.rules": [
        {
            "command": [
                "workbench.action.terminal.kill",
                "workbench.action.closePanel",
                "workbench.action.closeAuxiliaryBar"
            ],
            "condition": "always",
            "message": "close widgets when startup"
        }
    ],
    "backgroundCover.imagePath": "d:\\Pictures\\サクラ吹雪.png",
    "backgroundCover.opacity": 0.1,
    "code-runner.executorMap": {
        "c": "cd $dirWithoutTrailingSlash && gcc $fileName -o $fileNameWithoutExt && ./$fileNameWithoutExt",
        "cpp": "cd $dirWithoutTrailingSlash && g++ $fileName -o $fileNameWithoutExt && ./$fileNameWithoutExt",
        "java": "cd $dirWithoutTrailingSlash && javac -encoding utf-8 $fileName && java $fileNameWithoutExt",
        "rust": "cargo run # $fileName",
        "shellscript": "cd $dirWithoutTrailingSlash && bash $fileName"
    },
    "code-runner.runInTerminal": true,
    "debug.console.fontSize": 14,
    "debug.showBreakpointsInOverviewRuler": true,
    "diffEditor.diffAlgorithm": "advanced",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.accessibilitySupport": "off",
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorSurroundingLines": 5,
    "editor.detectIndentation": false,
    "editor.find.autoFindInSelection": "multiline",
    "editor.find.seedSearchStringFromSelection": "selection",
    "editor.fontFamily": "Sarasa Mono SC Nerd Font",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.guides.bracketPairs": true,
    "editor.lineNumbers": "relative",
    "editor.linkedEditing": true,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.showSlider": "always",
    "editor.minimap.size": "fill",
    "editor.renderLineHighlight": "all",
    "editor.renderWhitespace": "trailing",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.showFoldingControls": "always",
    "editor.stickyScroll.enabled": true,
    "editor.suggest.preview": true,
    "editor.suggest.showStatusBar": true,
    "editor.wordWrap": "on",
    "errorLens.followCursor": "activeLine",
    "explorer.confirmDragAndDrop": false,
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1,
        "Gruntfuggly.todo-tree": 1
    },
    "files.associations": {
        "*.txt": "plaintext"
    },
    "files.autoGuessEncoding": true,
    "files.autoSave": "afterDelay",
    "hediet.vscode-drawio.codeLinkActivated": true,
    "isort.args": [
        "--multi-line",
        "3",
        "--trailing-comma",
        "--profile",
        "black"
    ],
    "isort.check": true,
    "isort.severity": {
        "E": "Information"
    },
    "json.format.keepLines": true,
    "jupyter.askForKernelRestart": false,
    "latex-workshop.latex.autoBuild.run": "never",
    "latex-workshop.latex.autoClean.run": "onFailed",
    "latex-workshop.latex.recipe.default": "lastUsed",
    "latex-workshop.latex.recipes": [
        {
            "name": "XeLaTeX",
            "tools": [
                "xelatexmk"
            ]
        },
        {
            "name": "PDFLaTeX",
            "tools": [
                "pdflatex"
            ]
        },
        {
            "name": "BibTeX",
            "tools": [
                "bibtex"
            ]
        },
        {
            "name": "latexmk 🔃",
            "tools": [
                "latexmk"
            ]
        },
        {
            "name": "latexmk (latexmkrc)",
            "tools": [
                "latexmk_rconly"
            ]
        },
        {
            "name": "latexmk (lualatex)",
            "tools": [
                "lualatexmk"
            ]
        },
        {
            "name": "xelatexmk -> bibtex -> xelatexmk × 2",
            "tools": [
                "xelatexmk",
                "bibtex",
                "xelatexmk",
                "xelatexmk"
            ]
        },
        {
            "name": "pdflatex ➞ bibtex ➞ pdflatex × 2",
            "tools": [
                "pdflatex",
                "bibtex",
                "pdflatex",
                "pdflatex"
            ]
        },
        {
            "name": "Compile Rnw files",
            "tools": [
                "rnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Jnw files",
            "tools": [
                "jnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "tectonic",
            "tools": [
                "tectonic"
            ]
        }
    ],
    "latex-workshop.message.error.show": false,
    "latex-workshop.message.warning.show": false,
    "latex-workshop.showContextMenu": true,
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
    "Lua.diagnostics.globals": [
        "mp",
        "vim"
    ],
    "Lua.format.defaultConfig": {
        "max_line_length": "10000",
        "quote_style": "double",
        "trailing_table_separator": "smart"
    },
    "markdown.extension.list.indentationSize": "inherit",
    "markdown.marp.enableHtml": true,
    "markdown.marp.themes": [
        "./themes/academic.css"
    ],
    "markdown.occurrencesHighlight.enabled": true,
    "markdown.preview.breaks": true,
    "markdown.preview.fontSize": 14,
    "markdown.preview.scrollEditorWithPreview": false,
    "markdown.updateLinksOnFileMove.enabled": "always",
    "markdownConverter.ChromiumExecutablePath": "C:\\Users\\MasouShizuka\\AppData\\Local\\Vivaldi\\Application\\vivaldi.exe",
    "markdownConverter.ConversionType": [
        "PDF",
        "HTML"
    ],
    "markdownConverter.Document.HeaderContent": {
        "Center": "",
        "Left": "",
        "Right": ""
    },
    "mdtableeditor.commandViews": {
        "context": [
            "MdTableEditor.changeAlignCenter",
            "MdTableEditor.changeAlignLeft",
            "MdTableEditor.changeAlignRight",
            "MdTableEditor.columnSelectEmpty",
            "MdTableEditor.insertBottom",
            "MdTableEditor.insertLeft",
            "MdTableEditor.insertRight",
            "MdTableEditor.insertTop",
            "MdTableEditor.moveBottom",
            "MdTableEditor.moveLeft",
            "MdTableEditor.moveRight",
            "MdTableEditor.moveTop",
            "MdTableEditor.removeColumn",
            "MdTableEditor.removeRow",
            "MdTableEditor.sortNumberAsc",
            "MdTableEditor.sortNumberDesc",
            "MdTableEditor.sortTextAsc.ignore",
            "MdTableEditor.sortTextDesc.ignore"
        ],
        "toolbar": []
    },
    "notebook.cellToolbarLocation": {
        "default": "left",
        "jupyter-notebook": "left"
    },
    "notebook.displayOrder": [
        "image/png",
        "text/plain"
    ],
    "notebook.lineNumbers": "on",
    "notebook.output.scrolling": true,
    "oneDarkPro.italic": false,
    "pasteImage.path": "${currentFileDir}\\_images_${currentFileNameWithoutExt}",
    "python.analysis.inlayHints.pytestParameters": true,
    "python.defaultInterpreterPath": "C:\\Users\\MasouShizuka\\miniconda3\\python.exe",
    "python.languageServer": "Pylance",
    "search.defaultViewMode": "tree",
    "search.followSymlinks": false,
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "security.workspace.trust.enabled": false,
    "shellcheck.exclude": [
        "2148"
    ],
    "sshfs.configs": [],
    "swapdiff.ClosePreviousDiff": true,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.tabs.location": "left",
    "vscode-neovim.neovimExecutablePaths.win32": "D:\\Tools\\Neovim\\bin\\nvim.exe",
    "window.dialogStyle": "custom",
    "window.menuBarVisibility": "compact",
    "window.zoomLevel": 2,
    "wordcount_cjk.statusBarTextTemplate": "共 ${cjk} 字 ${en_words} 单词",
    "wordcount_cjk.statusBarTooltipTemplate": "中文字数：\\t\\t${cjk}\\n英文单词数：\\t\\t${en_words}\\nASCII 字符数：\\t${ascii}\\n非 ASCII 字符数：\\t${total - ascii}\\n空白字符数：\\t\\t${whitespace}\\n非空白字符数：\\t${total - whitespace}\\n总字符数：\\t\\t${total}",
    "workbench.colorCustomizations": {
        "editor.lineHighlightBackground": "#1073cf2d",
        "editor.lineHighlightBorder": "#9fced11f",
        "editor.selectionHighlightBackground": "#ffffff10",
        "editor.selectionHighlightBorder": "#dddddd",
        "editorCursor.foreground": "#528bff",
        "minimap.background": "#282c3433",
        "minimapSlider.background": "#9fced11f",
        "notebook.cellEditorBackground": "#21252b",
        "tab.activeBorder": "#d19a66",
        "titleBar.inactiveBackground": "#282c34"
    },
    "workbench.colorTheme": "One Dark Pro Flat",
    "workbench.editor.wrapTabs": true,
    "workbench.editorAssociations": {
        "*.epub": "cweijan.epubViewer",
        "*.gif": "cweijan.officeViewer",
        "*.md": "default"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.localHistory.enabled": false,
    "workbench.startupEditor": "none"
}